@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix cv: <http://data.europa.eu/m8g/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix gdi: <http://data.gdi.eu/core/p2/> .
@prefix dash: <http://datashapes.org/dash#> .

gdi:AgentPublisherShapeAgentPublisherShape a owl:Ontology;
  rdfs:label "Publisher class"@en;
  rdfs:comment "Excel template for Publisher class"@en;
  dct:description "This is a SHACL shape for the publisher Agent for GDI v1.1"@en;
  owl:versionInfo "0.1";
  dct:modified "2026-03-18T00:00:00.000Z"^^xsd:dateTime .

gdi:AgentPublisherShape a sh:NodeShape;
  rdfs:label "Publisher"@en;
  sh:targetClass foaf:Agent;
  sh:property <http://data.gdi.eu/core/p2/AgentPublisherShape#contact-point>,
    <http://data.gdi.eu/core/p2/AgentPublisherShape#dct:description>,
    <http://data.gdi.eu/core/p2/AgentPublisherShape#dct:type>,
    <http://data.gdi.eu/core/p2/AgentPublisherShape#foaf:name>.

<http://data.gdi.eu/core/p2/AgentPublisherShape#contact-point> sh:path cv:contactPoint;
  sh:name "contact point"@en;
  sh:description "Contact information that can be used to contact the Publisher."@en;
  sh:minCount 1;
  sh:maxCount 1;
  sh:node gdi:ContactPointShape;
  dash:viewer dash:DetailsViewer;
  dash:editor dash:BlankNodeEditor .

<http://data.gdi.eu/core/p2/AgentPublisherShape#dct:description> sh:path dct:description;
  sh:name "description"@en;
  sh:description "A description of the publisher activities."@en;
  sh:nodeKind sh:Literal;
  sh:uniqueLang true;
  dash:viewer dash:LiteralViewer;
  dash:editor dash:TextAreaEditor .

<http://data.gdi.eu/core/p2/AgentPublisherShape#dct:type> sh:path dct:type;
  sh:name "type"@en;
  sh:description "The nature or genre of the Publisher."@en;
  sh:maxCount 1;
  sh:nodeKind sh:IRI;
  dash:viewer dash:URIViewer;
  dash:editor dash:URIEditor .

<http://data.gdi.eu/core/p2/AgentPublisherShape#foaf:name> sh:path foaf:name;
  sh:name "name"@en;
  sh:description "A name of the agent."@en;
  sh:minCount 1;
  sh:nodeKind sh:Literal;
  sh:uniqueLang true;
  dash:viewer dash:LiteralViewer;
  dash:editor dash:TextAreaEditor .
